# Trading Bot — Environment Variables
# Copy this file to .env and fill in your credentials:
#   cp .env.template .env
#   chmod 600 .env
#
# The .env file is auto-loaded by scripts/start.sh
# It is excluded from version control via .gitignore

# Hyperliquid API Wallet (REQUIRED for live trading, optional for paper)
# Generate an API Wallet at: Hyperliquid > Settings > API
# Private key: 64 hex chars WITHOUT 0x prefix
# Wallet address: 0x + 40 hex chars
TB_PRIVATE_KEY=
TB_WALLET_ADDRESS=

# Anthropic API (optional — enables AI daily digest)
TB_ANTHROPIC_API_KEY=
