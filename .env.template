# Trading Bot — Environment Variables
# Copy this file to .env and fill in your credentials:
#   cp .env.template .env
#   chmod 600 .env
#
# The .env file is auto-loaded by scripts/start.sh
# It is excluded from version control via .gitignore

# Hyperliquid API Wallet (required for live trading)
# Generate an API Wallet at: Hyperliquid > Settings > API
# The private key is the API Wallet key (0x + 64 hex chars)
TB_PRIVATE_KEY=
TB_WALLET_ADDRESS=

# Claude AI Advisory (optional — enables twice-daily AI analysis)
TB_CLAUDE_API_KEY=

# FinancialModelingPrep (optional — enables S&P500 and DXY macro data)
TB_MACRO_API_KEY=
